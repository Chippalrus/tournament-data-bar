---
import { Font } from "astro:assets";
import { Image } from 'astro:assets';

const SHEET_ID    = '1yxS2osuAcafIArcSZuJSiZ23kwiahD192EVFSleXqjA';
const SHEET_NAME  = 'Sheet3';
const API_URL     = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&sheet=${SHEET_NAME}`;

async function getSheetData()
{
  const response    = await fetch( API_URL );
  const text        = await response.text();

  // google.visualization.Query.setResponse(...) raw json string
  const jsonString = text.substring( text.indexOf( "{" ), text.lastIndexOf( "}" ) + 1 );
  const json = JSON.parse( jsonString );

  // Mapping
  const cols = json.table.cols.map( ( col ) => col.label || '' );
  const rows = json.table.rows.map
  ( ( row ) =>
    {
      const rowData = {};
      row.c.forEach
      (
        ( cell, index ) =>
        {
          const key = cols[ index ] || `column_${index}`;
          rowData[ key ] = cell ? cell.v : null;  // raw value 
        }
      );
      return rowData;
    }
  );

  return rows;
}

const data = await getSheetData();

interface Props {
  maxFontSize?: number;
  minFontSize?: number;
}

const { maxFontSize = 100, minFontSize = 12 } = Astro.props;
---
<section id="data-container">
  <img class="bar-image" src="./images/UI_S2.png">
  <div class="overlay">
    {
      <div class="firstBox">
        <div class="bracket">{data[0].Bracket}</div>
        <div class="match">{data[0].Match}</div>
      </div>

      <div class="secondBox">
        <div class="map">{data[0].Map}</div>

        <div class="playerBoard">
          <div class="playerA">
            <span class="a_name" data-max={maxFontSize} data-min={minFontSize}>{data[0].A}</span>
            <div class="a_race">
            {(() => { if( data[0].A_Race.toLowerCase() == 'terran' ) 
                {
                    return <img src="./images/terran.png">
                }
                else if( data[0].A_Race.toLowerCase() == 'protoss' ) 
                {
                    return <img src="./images/protoss.png">
                }
                else if( data[0].A_Race.toLowerCase() == 'zerg'  ) 
                {
                    return <img src="./images/zerg.png">
                }
            })()}
            </div>
          </div>

          <div class="scoreBoard">
            <div class="playerAScore">{data[0].A_Score}</div>
            <div class="divider">-</div>
            <div class="playerBScore">{data[0].B_Score}</div>
          </div>

          <div class="playerB">
            <div class="b_race">
            {(() => { if( data[0].B_Race.toLowerCase() == 'terran' ) 
              {
                  return <img src="./images/terran.png">
              }
              else if( data[0].B_Race.toLowerCase() == 'protoss' ) 
              {
                  return <img src="./images/protoss.png">
              }
              else if( data[0].B_Race.toLowerCase() == 'zerg'  ) 
              {
                  return <img src="./images/zerg.png">
              }
            })()}
            </div>
            <span class="b_name" data-max={maxFontSize} data-min={minFontSize}>{data[0].B}</span>
          </div>
        </div>
      </div>
    }
  </div>
</section>

<script>
  const button = document.getElementById( 'refresh-btn' );
  const container = document.getElementById( 'data-container' );

  const SHEET_ID    = '1yxS2osuAcafIArcSZuJSiZ23kwiahD192EVFSleXqjA';
  const SHEET_NAME  = 'Sheet3';
  const API_URL     = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&sheet=${SHEET_NAME}`;

  async function refreshData()
  {
    if ( !container || !button ) return;
    button.textContent = 'Refreshing...';
    button.setAttribute( 'disabled', 'true' );

    try {
      const response = await fetch( API_URL );
      const text = await response.text();
      const jsonString = text.substring( text.indexOf( "{" ), text.lastIndexOf( "}" ) + 1 );
      const json = JSON.parse( jsonString );

      const cols = json.table.cols.map( ( col ) => col.label || '' );
      const rows = json.table.rows.map
      ( ( row ) =>
        {
          const rowData = {};
          row.c.forEach
          ( ( cell, index ) =>
            {
              const key = cols[ index ] || `column_${ index }`;
              rowData[ key ] = cell ? cell.v : null;
            }
          );
          return rowData;
        }
      );

      const data = rows;
       var a_Race = "";
       var b_Race = "";
      
      switch( data[0].A_Race.toLowerCase() )
      {
        case 'terran': a_Race = './images/terran.png'; break;
        case 'protoss': a_Race = './images/protoss.png'; break;
        case 'zerg': a_Race = './images/zerg.png'; break;
        default:break;
      }

      switch( data[0].B_Race.toLowerCase() )
      {
        case 'terran': b_Race = './images/terran.png'; break;
        case 'protoss': b_Race = './images/protoss.png'; break;
        case 'zerg': b_Race = './images/zerg.png'; break;
        default:break;
      }

      container.innerHTML =
      `<img class="bar-image" src="./images/UI_S2.png">
      <div class="overlay">
        <div class="firstBox">
          <div class="bracket">${data[0].Bracket}</div>
          <div class="match">${data[0].Match}</div>
        </div>

        <div class="secondBox">
          <div class="map">${data[0].Map}</div>

          <div class="playerBoard">
            <div class="playerA">
            <span class="a_name">${data[0].A}</span>
            <div class="a_race">
              <img src=${a_Race}>
            </div>
          </div>

            <div class="scoreBoard">
              <div class="playerAScore">${data[0].A_Score}</div>
              <div class="divider">-</div>
              <div class="playerBScore">${data[0].B_Score}</div>
            </div>

            <div class="playerB">
            <div class="b_race">
              <img src=${b_Race}>
            </div>
            <span class="b_name">${data[0].B}</span>
          </div>
          </div>
        </div>
      </div>`; 
    } catch ( error )
    {
      console.error( "Failed to fetch data:", error );
    } finally
    {
      button.textContent = 'Refresh Data';
      button.removeAttribute( 'disabled' );
    }
  }

  button?.addEventListener( 'click', refreshData );
</script>